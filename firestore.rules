rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: alternatives
    // Document ID: {alternativeId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-100 chars)
    //   - description: string (optional, 0-500 chars)
    //   - createdAt: timestamp (required)
    //
    // Collection: criteria
    // Document ID: {criterionId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-100 chars)
    //   - type: string (required, enum: ['maximize', 'minimize'])
    //   - weight: number (required, 0.1-10.0)
    //   - description: string (optional, 0-500 chars)
    //   - thresholdMin: number (optional)
    //   - thresholdMax: number (optional)
    //   - thresholdEnabled: boolean (legacy, optional)
    //   - thresholdValue: number (legacy, optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: evaluations
    // Document ID: {alternativeId}_{criterionId}
    // Fields:
    //   - alternative_id: string (required)
    //   - criterion_id: string (required)
    //   - value: number (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: rules
    // Document ID: {ruleId}
    // Fields:
    //   - id: string (required)
    //   - name: string (optional, 0-100 chars)
    //   - criterionId: string (required)
    //   - operator: string (required, enum: ['>', '>=', '<', '<=', '='])
    //   - value: number (required)
    //   - action: string (required, enum: ['exclude', 'adjust'])
    //   - adjustmentPercent: number (optional)
    //   - active: boolean (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "misam5302@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidAlternative(data) {
      return hasRequiredFields(['id', 'name', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'name', 'description', 'createdAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             data.createdAt is timestamp;
    }

    function isValidCriterion(data) {
      return hasRequiredFields(['id', 'name', 'type', 'weight', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'name', 'type', 'weight', 'description', 'thresholdMin', 'thresholdMax', 'thresholdEnabled', 'thresholdValue', 'createdAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type in ['maximize', 'minimize'] &&
             data.weight is number && data.weight >= 0.1 && data.weight <= 10.0 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             (!('thresholdMin' in data) || data.thresholdMin is number) &&
             (!('thresholdMax' in data) || data.thresholdMax is number) &&
             (!('thresholdEnabled' in data) || data.thresholdEnabled is bool) &&
             (!('thresholdValue' in data) || data.thresholdValue is number) &&
             data.createdAt is timestamp;
    }

    function isValidEvaluation(data) {
      return hasRequiredFields(['alternative_id', 'criterion_id', 'value', 'updatedAt']) &&
             hasOnlyAllowedFields(['alternative_id', 'criterion_id', 'value', 'updatedAt']) &&
             data.alternative_id is string && data.alternative_id.size() > 0 &&
             data.criterion_id is string && data.criterion_id.size() > 0 &&
             data.value is number &&
             data.updatedAt is timestamp;
    }

    function isValidRule(data) {
      return hasRequiredFields([
               'id',
               'criterionId',
               'operator',
               'value',
               'action',
               'active',
               'createdAt'
             ]) &&
             hasOnlyAllowedFields([
               'id',
               'name',
               'criterionId',
               'operator',
               'value',
               'action',
               'adjustmentPercent',
               'active',
               'createdAt'
             ]) &&
             data.id is string && data.id.size() > 0 &&
             data.criterionId is string && data.criterionId.size() > 0 &&
             data.operator in ['>', '>=', '<', '<=', '='] &&
             data.value is number &&
             data.action in ['exclude', 'adjust'] &&
             data.active is bool &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('adjustmentPercent' in data) || data.adjustmentPercent is number) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /alternatives/{alternativeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAlternative(request.resource.data);
      allow update: if isAuthenticated() && isValidAlternative(request.resource.data);
      allow delete: if isAdmin();
    }

    match /criteria/{criterionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCriterion(request.resource.data);
      allow update: if isAuthenticated() && isValidCriterion(request.resource.data);
      allow delete: if isAdmin();
    }

    match /evaluations/{evaluationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidEvaluation(request.resource.data);
      allow update: if isAuthenticated() && isValidEvaluation(request.resource.data);
      allow delete: if isAdmin();
    }

    match /rules/{ruleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRule(request.resource.data);
      allow update: if isAuthenticated() && isValidRule(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
